print(f"\033[1mGaps Register\033[0m — {len(watching)} watching, {len(closed)} resolved")
print()

for gap in watching:
    sev_colors = {'high': '\033[0;31m', 'medium': '\033[1;33m', 'low': '\033[0;36m'}
    sev = gap.get('severity', 'unknown')
