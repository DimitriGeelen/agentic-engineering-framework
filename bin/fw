    print(f"  {color}{gap['id']}\033[0m [{sev}]  {gap['title']}")
    trigger = gap.get('decision_trigger', '').strip().split('\n')[0]
    print(f"    Trigger: {trigger}")
    print()

if not watching:
    print("  \033[0;32mNo gaps being watched\033[0m")
PYEOF
        ;;
    decisions)
        python3 << 'PYDECISIONS'
import os, yaml, re

BOLD = '\033[1m'
GREEN = '\033[0;32m'
YELLOW = '\033[1;33m'
CYAN = '\033[0;36m'
NC = '\033[0m'

project_root = os.environ.get('PROJECT_ROOT', '.')

op_decisions = []
dec_file = os.path.join(project_root, '.context', 'project', 'decisions.yaml')
if os.path.isfile(dec_file):
    with open(dec_file) as f:
