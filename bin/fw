if os.path.isfile(dd_file):
    with open(dd_file) as f:
        lines = f.readlines()
    for line in lines:
        m = re.match(r'\|\s*(AD-\d+)\s*\|\s*(\S+)\s*\|\s*(.*?)\s*\|\s*(.*?)\s*\|\s*(.*?)\s*\|', line)
        if m:
            arch_decisions.append({
